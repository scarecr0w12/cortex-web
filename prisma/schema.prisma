generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  username      String           @unique
  passwordHash  String
  role          String           @default("user")
  avatar        String?
  bio           String?
  website       String?
  plugins       Plugin[]
  agents        AgentConfig[]
  reviews       SubmissionReview[]
  ratings       UserRating[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Plugin {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  version         String
  description     String
  kind            String
  entryPoint      String
  capabilities    String
  tags            String?
  author          String?
  authorUrl       String?
  homepage        String?
  repository      String?
  license         String?
  icon            String?
  readme          String?
  downloads       Int              @default(0)
  rating          Float            @default(0)
  githubStars     Int              @default(0)
  githubForks     Int              @default(0)
  githubTopics    String?
  githubLastCommit DateTime?
  categoryId      String?
  category        Category?        @relation(fields: [categoryId], references: [id])
  status          String           @default("pending")
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  reviews         SubmissionReview[]
  ratings         UserRating[]
  screenshots     Screenshot[]
  versions        PluginVersion[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AgentConfig {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  version         String
  description     String
  provider        String?
  model           String?
  temperature     Float?
  tools           String?
  tags            String?
  systemPrompt    String?
  soulContent     String?
  author          String?
  authorUrl       String?
  homepage        String?
  repository      String?
  license         String?
  icon            String?
  readme          String?
  downloads       Int              @default(0)
  rating          Float            @default(0)
  githubStars     Int              @default(0)
  githubForks     Int              @default(0)
  githubTopics    String?
  githubLastCommit DateTime?
  categoryId      String?
  category        Category?        @relation(fields: [categoryId], references: [id])
  status          String           @default("pending")
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  reviews         SubmissionReview[]
  ratings         UserRating[]
  screenshots     Screenshot[]
  versions        AgentVersion[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Category {
  id     String        @id @default(cuid())
  name   String        @unique
  slug   String        @unique
  plugins Plugin[]
  agents AgentConfig[]
}

model SubmissionReview {
  id            String      @id @default(cuid())
  pluginId      String?
  plugin        Plugin?     @relation(fields: [pluginId], references: [id])
  agentId       String?
  agent         AgentConfig? @relation(fields: [agentId], references: [id])
  reviewerId    String
  reviewer      User        @relation(fields: [reviewerId], references: [id])
  action        String      // "approved" | "rejected"
  notes         String?
  createdAt     DateTime    @default(now())
}

model UserRating {
  id            String      @id @default(cuid())
  pluginId      String?
  plugin        Plugin?     @relation(fields: [pluginId], references: [id])
  agentId       String?
  agent         AgentConfig? @relation(fields: [agentId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  rating        Int         // 1-5
  review        String?
  createdAt     DateTime    @default(now())
}

model Screenshot {
  id        String      @id @default(cuid())
  pluginId  String?
  plugin    Plugin?     @relation(fields: [pluginId], references: [id])
  agentId   String?
  agent     AgentConfig? @relation(fields: [agentId], references: [id])
  url       String
  alt       String?
  order     Int         @default(0)
}

model PluginVersion {
  id           String   @id @default(cuid())
  pluginId     String
  plugin       Plugin   @relation(fields: [pluginId], references: [id])
  version      String
  description  String
  entryPoint   String
  capabilities String
  kind         String
  createdAt    DateTime @default(now())
}

model AgentVersion {
  id           String      @id @default(cuid())
  agentId      String
  agent        AgentConfig @relation(fields: [agentId], references: [id])
  version      String
  description  String
  provider     String?
  model        String?
  temperature  Float?
  tools        String?
  tags         String?
  systemPrompt String?
  createdAt    DateTime    @default(now())
}
