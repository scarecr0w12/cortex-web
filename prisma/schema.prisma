generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  username        String           @unique
  passwordHash    String
  role            String           @default("user")
  avatar          String?
  bio             String?
  website         String?
  displayName     String?
  location        String?
  socialLinks     String?
  preferences     String?
  emailVerified   Boolean          @default(false)
  isActive        Boolean          @default(true)
  discordId       String?          @unique
  discordUsername String?
  plugins           Plugin[]
  agents            AgentConfig[]
  reviews           SubmissionReview[]
  ratings           UserRating[]
  auditLogs         AuditLog[]
  githubConnections GitHubConnection[]
  githubTopicScans  GitHubTopicScan[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]
  @@map("Permission")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  key         String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  @@map("Role")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("RolePermission")
}

model Plugin {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  version         String
  description     String
  kind            String
  entryPoint      String
  capabilities    String
  tags            String?
  author          String?
  authorUrl       String?
  homepage        String?
  repository      String?
  license         String?
  icon            String?
  readme          String?
  downloads       Int              @default(0)
  rating          Float            @default(0)
  githubStars     Int              @default(0)
  githubForks     Int              @default(0)
  githubTopics    String?
  githubLastCommit DateTime?
  githubImportId  String?
  categoryId      String?
  category        Category?        @relation(fields: [categoryId], references: [id])
  status          String           @default("pending")
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  reviews         SubmissionReview[]
  ratings         UserRating[]
  screenshots     Screenshot[]
  versions        PluginVersion[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AgentConfig {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  version         String
  description     String
  provider        String?
  model           String?
  temperature     Float?
  tools           String?
  tags            String?
  systemPrompt    String?
  soulContent     String?
  author          String?
  authorUrl       String?
  homepage        String?
  repository      String?
  license         String?
  icon            String?
  readme          String?
  downloads       Int              @default(0)
  rating          Float            @default(0)
  githubStars     Int              @default(0)
  githubForks     Int              @default(0)
  githubTopics    String?
  githubLastCommit DateTime?
  githubImportId  String?
  categoryId      String?
  category        Category?        @relation(fields: [categoryId], references: [id])
  status          String           @default("pending")
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  reviews         SubmissionReview[]
  ratings         UserRating[]
  screenshots     Screenshot[]
  versions        AgentVersion[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Category {
  id     String        @id @default(cuid())
  name   String        @unique
  slug   String        @unique
  plugins Plugin[]
  agents AgentConfig[]
}

model SubmissionReview {
  id            String      @id @default(cuid())
  pluginId      String?
  plugin        Plugin?     @relation(fields: [pluginId], references: [id])
  agentId       String?
  agent         AgentConfig? @relation(fields: [agentId], references: [id])
  reviewerId    String
  reviewer      User        @relation(fields: [reviewerId], references: [id])
  action        String      // "approved" | "rejected"
  notes         String?
  createdAt     DateTime    @default(now())
}

model UserRating {
  id            String      @id @default(cuid())
  pluginId      String?
  plugin        Plugin?     @relation(fields: [pluginId], references: [id])
  agentId       String?
  agent         AgentConfig? @relation(fields: [agentId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  rating        Int         // 1-5
  review        String?
  createdAt     DateTime    @default(now())
}

model Screenshot {
  id        String      @id @default(cuid())
  pluginId  String?
  plugin    Plugin?     @relation(fields: [pluginId], references: [id])
  agentId   String?
  agent     AgentConfig? @relation(fields: [agentId], references: [id])
  url       String
  alt       String?
  order     Int         @default(0)
}

model PluginVersion {
  id           String   @id @default(cuid())
  pluginId     String
  plugin       Plugin   @relation(fields: [pluginId], references: [id])
  version      String
  description  String
  entryPoint   String
  capabilities String
  kind         String
  createdAt    DateTime @default(now())
}

model AgentVersion {
  id           String      @id @default(cuid())
  agentId      String
  agent        AgentConfig @relation(fields: [agentId], references: [id])
  version      String
  description  String
  provider     String?
  model        String?
  temperature  Float?
  tools        String?
  tags         String?
  systemPrompt String?
  createdAt    DateTime    @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entity     String?
  entityId   String?
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@map("AuditLog")
}

model GitHubConnection {
  id              String   @id @default(cuid())
  owner           String
  repo            String
  branch          String   @default("main")
  isActive        Boolean  @default(true)
  lastSyncAt      DateTime?
  webhookSecret   String?
  syncPlugins     Boolean  @default(true)
  syncAgents      Boolean  @default(false)
  autoApprove     Boolean  @default(false)
  manifestPath    String   @default("cortex.json")
  createdById     String?
  createdBy       User?    @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([owner, repo])
  @@map("GitHubConnection")
}

model GitHubTopicScan {
  id         String   @id @default(cuid())
  topic      String
  status     String   @default("pending") // pending | running | completed | failed
  resultCount Int     @default(0)
  importedCount Int   @default(0)
  error      String?
  startedAt  DateTime?
  completedAt DateTime?
  createdById String?
  createdBy  User?    @relation(fields: [createdById], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  results    DiscoveredRepo[]

  @@map("GitHubTopicScan")
}

model DiscoveredRepo {
  id             String   @id @default(cuid())
  scanId         String
  scan           GitHubTopicScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  owner          String
  repo           String
  fullName       String
  description    String?
  htmlUrl        String
  stars          Int      @default(0)
  topics         String   @default("[]") // JSON array
  repoKind       String?  // "plugin" | "agent" | "unknown"
  manifestFound  Boolean  @default(false)
  manifestData   String?  // JSON of manifest if found
  importStatus   String   @default("pending") // pending | imported | skipped | error
  importedId     String?  // id of created Plugin or AgentConfig
  error          String?
  createdAt      DateTime @default(now())

  @@unique([scanId, fullName])
  @@map("DiscoveredRepo")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Setting")
}
