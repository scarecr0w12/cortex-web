# CortexPrism Web — Environment Variables
# Copy this file to .env and fill in your values.

# Database (SQLite path, relative to prisma/schema.prisma)
DATABASE_URL="file:./marketplace.db"

# Site URL (used for canonical links, OG images, etc.)
NEXT_PUBLIC_SITE_URL="https://cortexprism.io"
SITE_URL="https://cortexprism.io"

# GitHub repo for landing page stats
NEXT_PUBLIC_GITHUB_REPO="CortexPrism/cortex"

# JWT secret for auth tokens — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-in-production

# Development overrides:
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# GitHub API token (optional — without it, API rate limits are 60 req/hr)
# Create at https://github.com/settings/tokens (scopes: public_repo)
# GITHUB_TOKEN=

# SendGrid Email (optional — without it, email sending is disabled)
# Create API key at https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.example
# SENDGRID_FROM_EMAIL=noreply@cortexprism.io
# SENDGRID_FROM_NAME=CortexPrism

# Newsletter unsubscribe secret (optional — falls back to JWT_SECRET if unset)
# Generate with: openssl rand -hex 32
# NEWSLETTER_UNSUBSCRIBE_SECRET=change-this-to-a-random-secret-in-production

# SendGrid Event Webhook (optional — for real-time open/click/bounce tracking)
# URL: POST /api/newsletter/webhook — configure at https://app.sendgrid.com/settings/mail_settings
# SendGrid will send events: processed, delivered, open, click, bounce, unsubscribe, spamreport

# Email verification secret (optional — used to sign verification tokens)
# EMAIL_VERIFICATION_SECRET=change-this-to-a-random-secret-in-production

# Discord blog webhook URL (optional — used to manually post blog announcements to Discord)
# Create at Discord Server Settings → Integrations → Webhooks
# DISCORD_BLOG_WEBHOOK_URL=

# IndexNow API key (optional — used to notify search engines of content changes)
# Generate at https://www.bing.com/indexnow/getstarted or with: openssl rand -hex 16
# INDEXNOW_API_KEY=
