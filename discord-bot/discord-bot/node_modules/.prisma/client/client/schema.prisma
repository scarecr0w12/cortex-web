generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  username              String                 @unique
  passwordHash          String
  role                  String                 @default("user")
  avatar                String?
  bio                   String?
  website               String?
  displayName           String?
  location              String?
  socialLinks           String?
  preferences           String?
  emailVerified         Boolean                @default(false)
  isActive              Boolean                @default(true)
  discordId             String?                @unique
  discordUsername       String?
  githubId              String?                @unique
  githubToken           String?
  roleId                String?
  userRole              Role?                  @relation(fields: [roleId], references: [id])
  plugins               Plugin[]
  agents                AgentConfig[]
  reviews               SubmissionReview[]
  ratings               UserRating[]
  auditLogs             AuditLog[]
  githubConnections     GitHubConnection[]
  githubTopicScans      GitHubTopicScan[]
  notifications         Notification[]
  knowledgeBaseArticles KnowledgeBaseArticle[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("Permission")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  key         String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  users       User[]

  @@map("Role")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("RolePermission")
}

model Plugin {
  id               String             @id @default(cuid())
  name             String             @unique
  slug             String             @unique
  version          String
  description      String
  kind             String
  entryPoint       String
  capabilities     String
  tags             String?
  author           String?
  authorUrl        String?
  homepage         String?
  repository       String?
  license          String?
  icon             String?
  readme           String?
  downloads        Int                @default(0)
  rating           Float              @default(0)
  githubStars      Int                @default(0)
  githubForks      Int                @default(0)
  githubTopics     String?
  githubLastCommit DateTime?
  githubImportId   String?
  categoryId       String?
  category         Category?          @relation(fields: [categoryId], references: [id])
  status           String             @default("pending")
  userId           String?
  user             User?              @relation(fields: [userId], references: [id])
  reviews          SubmissionReview[]
  ratings          UserRating[]
  screenshots      Screenshot[]
  versions         PluginVersion[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model AgentConfig {
  id               String             @id @default(cuid())
  name             String             @unique
  slug             String             @unique
  version          String
  description      String
  provider         String?
  model            String?
  temperature      Float?
  tools            String?
  tags             String?
  systemPrompt     String?
  soulContent      String?
  author           String?
  authorUrl        String?
  homepage         String?
  repository       String?
  license          String?
  icon             String?
  readme           String?
  downloads        Int                @default(0)
  rating           Float              @default(0)
  githubStars      Int                @default(0)
  githubForks      Int                @default(0)
  githubTopics     String?
  githubLastCommit DateTime?
  githubImportId   String?
  categoryId       String?
  category         Category?          @relation(fields: [categoryId], references: [id])
  status           String             @default("pending")
  userId           String?
  user             User?              @relation(fields: [userId], references: [id])
  reviews          SubmissionReview[]
  ratings          UserRating[]
  screenshots      Screenshot[]
  versions         AgentVersion[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Category {
  id      String        @id @default(cuid())
  name    String        @unique
  slug    String        @unique
  plugins Plugin[]
  agents  AgentConfig[]
}

model SubmissionReview {
  id         String       @id @default(cuid())
  pluginId   String?
  plugin     Plugin?      @relation(fields: [pluginId], references: [id])
  agentId    String?
  agent      AgentConfig? @relation(fields: [agentId], references: [id])
  reviewerId String
  reviewer   User         @relation(fields: [reviewerId], references: [id])
  action     String // "approved" | "rejected"
  notes      String?
  createdAt  DateTime     @default(now())
}

model UserRating {
  id        String       @id @default(cuid())
  pluginId  String?
  plugin    Plugin?      @relation(fields: [pluginId], references: [id])
  agentId   String?
  agent     AgentConfig? @relation(fields: [agentId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  rating    Int // 1-5
  review    String?
  createdAt DateTime     @default(now())
}

model Screenshot {
  id       String       @id @default(cuid())
  pluginId String?
  plugin   Plugin?      @relation(fields: [pluginId], references: [id])
  agentId  String?
  agent    AgentConfig? @relation(fields: [agentId], references: [id])
  url      String
  alt      String?
  order    Int          @default(0)
}

model PluginVersion {
  id           String   @id @default(cuid())
  pluginId     String
  plugin       Plugin   @relation(fields: [pluginId], references: [id])
  version      String
  description  String
  entryPoint   String
  capabilities String
  kind         String
  createdAt    DateTime @default(now())
}

model AgentVersion {
  id           String      @id @default(cuid())
  agentId      String
  agent        AgentConfig @relation(fields: [agentId], references: [id])
  version      String
  description  String
  provider     String?
  model        String?
  temperature  Float?
  tools        String?
  tags         String?
  systemPrompt String?
  createdAt    DateTime    @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  String?
  ip        String?
  createdAt DateTime @default(now())

  @@map("AuditLog")
}

model GitHubConnection {
  id            String    @id @default(cuid())
  owner         String
  repo          String
  branch        String    @default("main")
  isActive      Boolean   @default(true)
  lastSyncAt    DateTime?
  webhookSecret String?
  syncPlugins   Boolean   @default(true)
  syncAgents    Boolean   @default(false)
  autoApprove   Boolean   @default(false)
  manifestPath  String    @default("cortex.json")
  createdById   String?
  createdBy     User?     @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([owner, repo])
  @@map("GitHubConnection")
}

model GitHubTopicScan {
  id            String    @id @default(cuid())
  topic         String
  status        String    @default("pending") // pending | running | completed | failed
  resultCount   Int       @default(0)
  importedCount Int       @default(0)
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdById   String?
  createdBy     User?     @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  results DiscoveredRepo[]

  @@map("GitHubTopicScan")
}

model DiscoveredRepo {
  id            String          @id @default(cuid())
  scanId        String
  scan          GitHubTopicScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  owner         String
  repo          String
  fullName      String
  description   String?
  htmlUrl       String
  stars         Int             @default(0)
  topics        String          @default("[]") // JSON array
  repoKind      String? // "plugin" | "agent" | "unknown"
  manifestFound Boolean         @default(false)
  manifestData  String? // JSON of manifest if found
  importStatus  String          @default("pending") // pending | imported | skipped | error
  importedId    String? // id of created Plugin or AgentConfig
  error         String?
  createdAt     DateTime        @default(now())

  @@unique([scanId, fullName])
  @@map("DiscoveredRepo")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "submission_approved" | "submission_rejected" | "new_submission" | "system"
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("Notification")
}

model KnowledgeBaseArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  description String?
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdBy   String?
  author      User?    @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("KnowledgeBaseArticle")
}

model ReleaseWatch {
  id                     String    @id @default(cuid())
  owner                  String
  repo                   String
  watchType              String    @default("release") // "release" | "tag" | "both"
  lastReleaseTag         String?
  lastReleasePublishedAt DateTime?
  channelId              String
  guildId                String
  isActive               Boolean   @default(true)
  createdBy              String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([owner, repo, guildId])
  @@map("ReleaseWatch")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Setting")
}

model GuildConfig {
  id                    String             @id @default(cuid())
  guildId               String             @unique
  guildName             String?
  logChannelId          String?
  modRoleId             String?
  adminRoleId           String?
  muteRoleId            String?
  autoModEnabled        Boolean            @default(false)
  welcomeEnabled        Boolean            @default(false)
  welcomeMessage        String?
  welcomeChannelId      String?
  leaveEnabled          Boolean            @default(false)
  leaveMessage          String?
  leaveChannelId        String?
  slowmodeDefault       Int                @default(0)
  maxWarnsBeforeBan     Int                @default(3)
  announcementChannelId String?
  ticketCategoryId      String?
  ticketLogChannelId    String?
  ticketStaffRoleId     String?
  levelingEnabled       Boolean            @default(false)
  levelingMessage       String?
  levelingChannelId     String?
  starboardEnabled      Boolean            @default(false)
  starboardChannelId    String?
  starboardThreshold    Int                @default(3)
  moderationActions     ModerationAction[]
  reactionRoles         ReactionRole[]
  autoModRules          AutoModRule[]
  polls                 Poll[]
  tickets               Ticket[]
  channelConfigs        ChannelConfig[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@map("GuildConfig")
}

model ModerationAction {
  id           String       @id @default(cuid())
  guildId      String
  guildConfig  GuildConfig? @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  actionType   String // warn | mute | unmute | kick | ban | unban | purge | lockdown | unlock | nickname
  moderatorId  String
  moderatorTag String?
  targetId     String
  targetTag    String?
  reason       String?
  duration     String? // duration in ms for timed actions (mute)
  expiresAt    DateTime? // when a timed action expires
  metadata     String? // JSON for extra data (message count for purge, etc.)
  createdAt    DateTime     @default(now())

  @@index([guildId])
  @@index([targetId])
  @@index([moderatorId])
  @@map("ModerationAction")
}

model ReactionRole {
  id          String      @id @default(cuid())
  guildId     String
  guildConfig GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  channelId   String
  messageId   String?
  roleId      String
  emoji       String
  label       String?
  type        String      @default("toggle") // toggle | single | verify
  createdAt   DateTime    @default(now())

  @@index([guildId])
  @@map("ReactionRole")
}

model AutoModRule {
  id          String      @id @default(cuid())
  guildId     String
  guildConfig GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  type        String // keyword_filter | invite_filter | spam_filter | link_filter | mention_limit | caps_filter
  name        String
  enabled     Boolean     @default(true)
  action      String      @default("warn") // warn | mute | kick | ban | delete
  duration    Int? // mute duration in minutes (for mute action)
  config      String? // JSON config (keywords, threshold, excluded channels/roles, etc.)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([guildId])
  @@map("AutoModRule")
}

model Poll {
  id            String      @id @default(cuid())
  guildId       String
  guildConfig   GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  channelId     String
  messageId     String?
  title         String
  description   String?
  options       String // JSON array of {emoji, label, votes}
  allowMultiple Boolean     @default(false)
  isActive      Boolean     @default(true)
  createdBy     String
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([guildId])
  @@map("Poll")
}

model Ticket {
  id            String          @id @default(cuid())
  guildId       String
  guildConfig   GuildConfig     @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  channelId     String          @unique
  userId        String
  userTag       String?
  subject       String
  status        String          @default("open") // open | claimed | closed | deleted
  claimedBy     String?
  claimedByTag  String?
  closedAt      DateTime?
  closedBy      String?
  closeReason   String?
  transcriptUrl String?
  priority      String          @default("normal") // low | normal | high | urgent
  messages      TicketMessage[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([guildId])
  @@index([userId])
  @@index([status])
  @@map("Ticket")
}

model TicketMessage {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId       String
  userTag      String?
  content      String
  attachments  String? // JSON array of URLs
  isStaffReply Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([ticketId])
  @@map("TicketMessage")
}

model ChannelConfig {
  id            String      @id @default(cuid())
  guildId       String
  guildConfig   GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  channelId     String      @unique
  channelName   String?
  slowmode      Int         @default(0)
  isLocked      Boolean     @default(false)
  isNsfw        Boolean     @default(false)
  autoModExempt Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([guildId])
  @@map("ChannelConfig")
}
