{
  "name": "cortex-discord-bot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../.env node --import dotenv/config node_modules/.bin/tsx src/index.ts",
    "build": "tsc",
    "start": "DOTENV_CONFIG_PATH=../.env node --import dotenv/config dist/index.js",
    "deploy-commands": "DOTENV_CONFIG_PATH=../.env node --import dotenv/config node_modules/.bin/tsx src/deploy-commands.ts",
    "db:generate": "prisma generate --schema=../prisma/schema.prisma && cp -r ../node_modules/.prisma/client node_modules/.prisma/client",
    "postinstall": "npm run db:generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.18.0",
    "dotenv": "^17.4.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
